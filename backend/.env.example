# FC-Inventory Backend — Environment Variables
# Copy to .env and fill in values. NEVER commit .env

# App
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
APP_DEBUG=true
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://maverick:mav-secret@localhost:5432/mavdb
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Multi-tenancy
DEFAULT_TENANT_HEADER=X-Tenant-ID

# AWS S3 (for report storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=fc-inventory-reports

# Email (Celery worker)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
